[Bb]uild/
[Bb]uild/Engine
[Bb]uild/SDK
[Bb]uild/Shared
[Bb]in/

obj/

*.user
*.DotSettings
.vs/
.vscode/

# Node artifact files
node_modules/
dist/

# Compiled Java class files
*.class

# Compiled Python bytecode
*.py[cod]

# Log files
*.log

# Package files
*.jar

# Markdown Linter (Vscode extension) settings
.markdownlint.json

# Maven
target/
dist/

# JetBrains IDE
.idea/

# Unit test reports
TEST*.xml

# Generated by MacOS
.DS_Store

# Generated by Windows
Thumbs.db

# Applications
*.app
*.exe
*.war

# Large media files
*.mp4
*.tiff
*.avi
*.flv
*.mov
*.wmv

# BenchmarkDotNet output
BenchmarkDotNet.Artifacts/

